# ================================
# gomcp Server Configuration
# ================================

# --------------------------------
# Server Settings
# --------------------------------
MCP_HOST=localhost
MCP_PORT=8081
MCP_TRANSPORT_PROTOCOL=http
MCP_HOST_ENDPOINT=http://localhost:8081
ENVIRONMENT=development

# SSL/TLS (optional)
# MCP_SSL_KEYFILE=/path/to/key.pem
# MCP_SSL_CERTFILE=/path/to/cert.pem

# --------------------------------
# Logging
# --------------------------------
LOG_LEVEL=INFO

# --------------------------------
# CORS Settings
# --------------------------------
CORS_ENABLED=false
CORS_ORIGINS=*
CORS_CREDENTIALS=true
CORS_METHODS=*
CORS_HEADERS=*

# --------------------------------
# Authentication
# --------------------------------
ENABLE_AUTH=false

# Session secret (REQUIRED in production)
# SESSION_SECRET=change-this-secret-key-in-production

# --------------------------------
# SSO/OAuth Configuration
# --------------------------------
# SSO_CLIENT_ID=your-client-id
# SSO_CLIENT_SECRET=your-client-secret
# SSO_CALLBACK_URL=http://localhost:8081/auth/callback
# SSO_AUTHORIZATION_URL=https://sso.example.com/authorize
# SSO_TOKEN_URL=https://sso.example.com/token
# SSO_INTROSPECTION_URL=https://sso.example.com/introspect

# --------------------------------
# Cursor IDE Compatibility
# --------------------------------
CURSOR_COMPATIBLE_SSE=false
COMPATIBLE_WITH_CURSOR=false
USE_EXTERNAL_BROWSER_AUTH=false

# --------------------------------
# PostgreSQL Database
# --------------------------------
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=gomcp
# POSTGRES_USER=gomcp
# POSTGRES_PASSWORD=changeme
# POSTGRES_POOL_SIZE=10
# POSTGRES_MAX_CONNECTIONS=20

# --------------------------------
# Development Settings
# --------------------------------
# Uncomment for Cursor IDE development
# MCP_TRANSPORT_PROTOCOL=http
# MCP_PORT=8081
# CURSOR_COMPATIBLE_SSE=true
# ENABLE_AUTH=false
# LOG_LEVEL=DEBUG

# Uncomment for Claude Desktop development
# MCP_TRANSPORT_PROTOCOL=stdio
# ENABLE_AUTH=false
